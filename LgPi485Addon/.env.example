LG_PI485_STATE_PATH=.local-test/lg_pi485_state.json
MQTT_TOPIC_PREFIX=devlg
MQTT_BROKER_URL=homeassistant.local
MQTT_PORT=1883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
EW11_HOST=ew11.local
EW11_PORT=8899
LG_PI485_TX_BYTE_0=0x80
LG_PI485_REQUEST_ID=0xA3
LG_PI485_INDOOR_UNITS=4
LG_PI485_INDOOR_UNIT_IDS=1,2,3,4
LG_PI485_COOLING_ONLY=true
LG_PI485_SUPPORTED_HVAC_MODES=off,cool,fan_only,dry,auto
LG_PI485_CONTROL_ENABLED=false
LG_PI485_MONITOR_ENABLED=false
LG_PI485_MONITOR_DEVICE_IDS=
LG_PI485_MONITOR_LOG_UNCHANGED=false
LG_PI485_POLL_INTERVAL_MS=2000
LG_PI485_POLL_SPACING_MS=150
LG_PI485_COMMAND_DRAIN_INTERVAL_MS=50
LG_PI485_UNKNOWN_PACKET_CAPTURE_ENABLED=false
LG_PI485_UNKNOWN_PACKET_CAPTURE_PATH=.local-test/lg_pi485_unknown_packets.jsonl
LG_PI485_LOG_UNKNOWN_PACKETS=false
